#!/usr/bin/env bash
# docpush - Push markdown files to docs-server
# Usage:
#   docpush file.md                    Push file to server
#   docpush folder/                    Push all .md files in folder
#   docpush --token TOKEN file.md      Push with auth token

set -euo pipefail

# --- Config (override with env vars) ---
DOCS_SERVER="${DOCS_SERVER:-https://tu-dominio.com}"
DOCS_TOKEN="${DOCS_TOKEN:-}"

# --- Parse args ---
FILES=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --server) DOCS_SERVER="$2"; shift 2 ;;
    --token) DOCS_TOKEN="$2"; shift 2 ;;
    --help|-h)
      echo "Usage: docpush [options] <file.md|folder/>"
      echo ""
      echo "Options:"
      echo "  --server URL    Server URL (default: \$DOCS_SERVER)"
      echo "  --token TOKEN   Auth token (default: \$DOCS_TOKEN)"
      echo ""
      echo "Environment:"
      echo "  DOCS_SERVER     Server URL"
      echo "  DOCS_TOKEN      Auth token"
      exit 0
      ;;
    *) FILES+=("$1"); shift ;;
  esac
done

if [[ ${#FILES[@]} -eq 0 ]]; then
  echo "Error: No files specified. Use 'docpush --help' for usage."
  exit 1
fi

if [[ -z "$DOCS_TOKEN" ]]; then
  echo "Error: Auth token required. Set DOCS_TOKEN or use --token."
  exit 1
fi

# --- Expand directories ---
EXPANDED=()
for f in "${FILES[@]}"; do
  if [[ -d "$f" ]]; then
    while IFS= read -r -d '' md; do
      EXPANDED+=("$md")
    done < <(find "$f" -name '*.md' -print0)
  elif [[ -f "$f" ]]; then
    EXPANDED+=("$f")
  else
    echo "Warning: '$f' not found, skipping"
  fi
done

if [[ ${#EXPANDED[@]} -eq 0 ]]; then
  echo "Error: No .md files found."
  exit 1
fi

# --- Push files ---
for filepath in "${EXPANDED[@]}"; do
  filename=$(basename "$filepath")
  content=$(cat "$filepath")

  json_content=$(printf '%s' "$content" | python3 -c 'import sys,json; print(json.dumps(sys.stdin.read()))' 2>/dev/null \
    || printf '%s' "$content" | node -e 'let d="";process.stdin.on("data",c=>d+=c);process.stdin.on("end",()=>console.log(JSON.stringify(d)))' 2>/dev/null)
  json_file=$(printf '%s' "$filename" | python3 -c 'import sys,json; print(json.dumps(sys.stdin.read()))' 2>/dev/null \
    || printf '%s' "$filename" | node -e 'let d="";process.stdin.on("data",c=>d+=c);process.stdin.on("end",()=>console.log(JSON.stringify(d)))' 2>/dev/null)

  payload="{\"file\":$json_file,\"content\":$json_content}"
  echo -n "Pushing $filename... "

  result=$(curl -s -w "\n%{http_code}" -X POST "$DOCS_SERVER/api/push" \
    -H "Content-Type: application/json" \
    -H "X-Pub-Token: $DOCS_TOKEN" \
    -d "$payload")

  http_code=$(echo "$result" | tail -1)
  body=$(echo "$result" | sed '$d')

  if [[ "$http_code" == "200" ]]; then
    echo "OK"
  else
    echo "FAILED ($http_code): $body"
  fi
done
