PORT=3500

# Raiz unica de storage. Dentro vive: users/<id>/, teams/<slug>/, public/
STORAGE_DIR=./storage

# Seed inicial — solo se usa si la tabla users esta vacia al arrancar.
# Despues de bootear la DB, gestiona users con `npm run user:create`.
ADMIN_USER=admin
ADMIN_PASS=change-me

# Generar con: openssl rand -base64 64
JWT_SECRET=change-me-in-production

# PostgreSQL. Para dev con docker-compose usar el servicio local:
DATABASE_URL=postgres://mdreader:mdreader@localhost:5432/mdreader
