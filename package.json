{
  "name": "md-reader",
  "version": "1.0.0",
  "type": "module",
  "description": "Servidor de documentos Markdown como sitio web editable",
  "scripts": {
    "start": "node --env-file=.env src/index.js",
    "dev": "concurrently -n server,vite -c blue,green \"node --env-file=.env --watch src/index.js\" \"cd client && npm run dev\"",
    "build:client": "cd client && npm run build",
    "build": "npm run build:client",
    "postinstall": "cd client && npm install"
  },
  "dependencies": {
    "cookie-parser": "^1.4.7",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "markdown-it": "^14.1.1"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
