{
  "name": "md-reader",
  "version": "1.0.0",
  "type": "module",
  "description": "Servidor de documentos Markdown como sitio web editable",
  "scripts": {
    "start": "node --env-file=.env dist/src/index.js",
    "dev": "concurrently -n server,vite -c blue,green \"tsx watch --env-file=.env src/index.ts\" \"cd client && npm run dev\"",
    "build:client": "cd client && npm run build",
    "build:server": "tsc -p tsconfig.server.json",
    "build": "npm run build:client && npm run build:server",
    "typecheck": "tsc -p tsconfig.server.json --noEmit",
    "lint": "eslint src shared",
    "postinstall": "cd client && npm install"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "cookie-parser": "^1.4.7",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "markdown-it": "^14.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/archiver": "^7.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.19.17",
    "concurrently": "^9.2.1",
    "eslint": "^10.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.1"
  }
}
